<!DOCTYPE html>
<!-- =============================================
     STUDENT TEMPLATE 1 — Soft Lavender (S3)
     Fields: name, roll, cls, session, dob, section
     Variables: logo, schoolName, schoolAddress,
                photo, name, roll, cls, session,
                dob, section, principalName, primaryColor
     ============================================= -->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student ID - Soft Lavender</title>
  <style>
    :root {
      --primary: <%= locals.primaryColor || '#6c63d5' %>;
      --primary-light: <%= locals.primaryColor ? locals.primaryColor + '22' : '#6c63d522' %>;
      --primary-mid:  <%= locals.primaryColor ? locals.primaryColor + '55' : '#6c63d555' %>;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      width: 85.6mm; height: 54mm;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }
    .card {
      position: relative;
      width: 85.6mm; height: 54mm;
      background: #ffffff;
      border-radius: 3mm;
      overflow: hidden;
      border: 0.3mm solid #e0dff8;
    }

    /* ── LEFT PURPLE PANEL ── */
    .left-panel {
      position: absolute;
      top: 0; left: 0;
      width: 28mm; height: 100%;
      background: var(--primary);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding-top: 2.5mm;
      gap: 1mm;
    }

    /* ── LOGO ── */
    .logo-box {
      width: 8mm;
      height: 8mm;
      border-radius: 1.5mm;
      background: rgba(255,255,255,0.2);
      border: 0.5mm solid rgba(255,255,255,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .logo-box img {
      width: 100%; height: 100%;
      object-fit: contain;
    }

    .school-name {
      font-size: 5pt;
      font-weight: 800;
      color: #fff;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.3pt;
      padding: 0 2mm;
      line-height: 1.3;
    }
    .school-addr {
      font-size: 3.5pt;
      color: rgba(255,255,255,0.75);
      text-align: center;
      padding: 0 1.5mm;
    }

    /* circle photo */
    .photo-ring {
      width: 16mm; height: 16mm;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
      display: flex; align-items: center; justify-content: center;
      margin-top: 1.5mm;
    }
    .photo-inner {
      width: 13mm; height: 13mm;
      border-radius: 50%;
      background: rgba(255,255,255,0.35);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .photo-inner img { width:100%; height:100%; object-fit:cover; }

    /* STUDENT badge bottom of left panel */
    .role-badge {
      position: absolute;
      bottom: 3mm;
      left: 0; width: 28mm;
      text-align: center;
      font-size: 5pt;
      font-weight: 800;
      color: rgba(255,255,255,0.9);
      letter-spacing: 1.5pt;
      text-transform: uppercase;
    }

    /* ── RIGHT CONTENT ── */
    .right {
      position: absolute;
      top: 0; left: 28mm; right: 0; bottom: 14mm;
      display: flex;
      flex-direction: column;
      padding: 3.5mm 3mm 2mm 3.5mm;
    }

    .student-name {
      font-size: 11pt;
      font-weight: 800;
      color: #1a1a3e;
      line-height: 1;
      margin-bottom: 0.8mm;
    }
    .roll-no {
      font-size: 5pt;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 2.5mm;
    }

    /* field rows with icon */
    .fields { flex: 1; display: flex; flex-direction: column; gap: 1.4mm; }

    /* Standard field (icon + label + value, label has fixed width) */
    .field { display: flex; align-items: center; gap: 1.5mm; }
    .field-icon {
      width: 3.5mm; height: 3.5mm;
      background: var(--primary-light);
      border-radius: 0.5mm;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .field-icon svg { width: 2.2mm; height: 2.2mm; }
    .field-label {
      font-size: 4.5pt; font-weight: 700;
      color: var(--primary);
      width: 10mm; flex-shrink: 0;
      text-transform: uppercase;
      letter-spacing: 0.3pt;
    }
    .field-value {
      font-size: 5pt; font-weight: 700; color: #222;
    }

    /* ── INLINE FIELD — everything on one line, no wrapping ── */
    .field-inline {
      display: flex;
      align-items: center;
      gap: 1.5mm;
      flex-wrap: nowrap;   /* ← prevent wrapping */
    }
    .field-inline .field-icon {
      width: 3.5mm; height: 3.5mm;
      background: var(--primary-light);
      border-radius: 0.5mm;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .field-inline .field-icon svg { width: 2.2mm; height: 2.2mm; }
    .field-inline .field-label {
      font-size: 4pt;          /* slightly smaller so label fits */
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.2pt;
      white-space: nowrap;     /* ← never wrap label text */
      flex-shrink: 0;
    }
    .field-inline .field-colon {
      font-size: 4.5pt;
      color: var(--primary);
      margin: 0 0.3mm;
      flex-shrink: 0;
    }
    .field-inline .field-value {
      font-size: 5pt;
      font-weight: 700;
      color: #222;
      white-space: nowrap;     /* ← never wrap value text */
    }

    /* ── BOTTOM STRIP ── */
    .bottom-strip {
      position: absolute;
      bottom: 0; left: 28mm; right: 0;
      height: 14mm;
      background: var(--primary-light);
      border-top: 0.3mm solid var(--primary-mid);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3mm;
    }
    .qr { width: 9mm; height: 9mm; }
    .qr svg { width: 100%; height: 100%; }

    /* White reserved QR area (center-right notch) */
    .white-qr {
      position: absolute;
      bottom: 5.5mm;
      right: 24mm;
      width: 12mm;
      height: 9mm;
      background: #ffffff;
      border-radius: 0.6mm;
      padding: 0.5mm;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 0.6mm rgba(0,0,0,0.06);
      z-index: 8;
    }
    .white-qr img { width:100%; height:100%; object-fit:contain; }

    .signature { text-align: center; }
    .sig-name {
      font-family: Georgia, serif;
      font-size: 5.5pt; font-style: italic; font-weight: 700;
      color: #333;
    }
    .sig-line { border-top: 0.5px solid #999; margin: 0.8mm 0 0.3mm; }
    .sig-title { font-size: 3pt; color: #888; text-transform: uppercase; letter-spacing: 0.5pt; }
  </style>
</head>
<body>
<div class="card">

  <!-- LEFT PANEL -->
  <div class="left-panel">

    <!-- LOGO -->
    <% if (locals.logo) { %>
      <div class="logo-box"><img src="<%= logo %>" alt="Logo"></div>
    <% } else { %>
      <div class="logo-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2" width="14" height="14">
          <path d="M12 3L2 9l10 6 10-6-10-6z"/>
          <path d="M2 17l10 6 10-6"/>
          <path d="M2 13l10 6 10-6"/>
        </svg>
      </div>
    <% } %>

    <div class="school-name"><%= locals.schoolName || 'School Name' %></div>
    <div class="school-addr"><%= locals.schoolAddress || 'City' %></div>

    <div class="photo-ring">
      <div class="photo-inner">
        <% if (locals.photo) { %>

        <!-- White reserved QR box (keeps existing layout unchanged) -->
        <div class="white-qr">
          <% if (locals.qrCode) { %>
            <img src="<%= locals.qrCode %>" alt="QR Code">
          <% } else { %>
            <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
              <rect x="3.5" y="3.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
              <rect x="18" y="2" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
              <rect x="19.5" y="3.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
              <rect x="2" y="18" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
              <rect x="3.5" y="19.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
            </svg>
          <% } %>
        </div>
          <img src="<%= photo %>" alt="Photo">
        <% } else { %>
          <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="1.5" width="22" height="22">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        <% } %>
      </div>
    </div>

    <div class="role-badge">STUDENT</div>
  </div>

  <!-- RIGHT CONTENT -->
  <div class="right">
    <div class="student-name"><%= locals.name || 'Student Name' %></div>
    <div class="roll-no">Roll No: <%= locals.roll || 'N/A' %></div>
    <div class="fields">
      <div class="field">
        <div class="field-icon"><svg viewBox="0 0 24 24" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h4"/></svg></div>
        <span class="field-label">Class</span>
        <span class="field-value"><%= locals.cls || 'N/A' %></span>
      </div>
      <div class="field">
        <div class="field-icon"><svg viewBox="0 0 24 24" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></div>
        <span class="field-label">Session</span>
        <span class="field-value"><%= locals.session || 'N/A' %></span>
      </div>
      <div class="field-inline">
        <div class="field-icon"><svg viewBox="0 0 24 24" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h4"/></svg></div>
        <span class="field-label">Student ID</span>
        <span class="field-colon">:</span>
        <span class="field-value"><%= locals.studentId || 'N/A' %></span>
      </div>
      <div class="field-inline">
        <div class="field-icon"><svg viewBox="0 0 24 24" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
        <span class="field-label">Issue Date</span>
        <span class="field-colon">:</span>
        <span class="field-value"><%= locals.issueDate || 'N/A' %></span>
      </div>
    </div>
  </div>

  <!-- BOTTOM STRIP -->
  <div class="bottom-strip">
    <div class="qr">
      <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="2" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
        <rect x="3.5" y="3.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="18" y="2" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
        <rect x="19.5" y="3.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="2" y="18" width="8" height="8" fill="none" stroke="<%= locals.primaryColor||'#6c63d5' %>" stroke-width="0.8"/>
        <rect x="3.5" y="19.5" width="5" height="5" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="13" y="4" width="2" height="2" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="16" y="7" width="2" height="2" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="18" y="18" width="2" height="2" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
        <rect x="22" y="22" width="2" height="2" fill="<%= locals.primaryColor||'#6c63d5' %>"/>
      </svg>
    </div>
    <div class="signature">
      <div class="sig-name"><%= locals.principalName || 'Principal' %></div>
      <div class="sig-line"></div>
      <div class="sig-title">Principal Signature</div>
    </div>
  </div>

</div>
</body>
</html>