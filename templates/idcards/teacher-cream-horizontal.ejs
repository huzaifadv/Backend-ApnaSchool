<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Teacher ID Card - Cream Navy</title>

  <style>
    /* ============================================================
       RESET
       ============================================================ */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }


    /* ============================================================
       CARD CONTAINER (CR80: 85.6mm × 54mm)
       ============================================================ */
    body {
      width: 85.6mm;
      height: 54mm;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    .card {
      position: relative;
      width: 85.6mm;
      height: 54mm;
      background: #f5f0e8;
      overflow: hidden;
    }


    /* ============================================================
       NAVY HEADER BAND
       ============================================================ */
    .header {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 15mm;
      display: flex;
      align-items: center;
      gap: 2mm;
      padding: 0 2.5mm;
      background: <%= primaryColor %>;
    }

    .header__logo {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 10mm;
      height: 10mm;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 50%;
      overflow: hidden;
    }

    .header__logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .header__text {
      flex: 1;
    }

    .header__school-name {
      font-size: 7pt;
      font-weight: 700;
      color: #ffffff;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .header__school-address {
      margin-top: 0.5mm;
      font-size: 3.8pt;
      color: #aabbcc;
    }


    /* ============================================================
       TEACHER PHOTO (left, below header)
       ============================================================ */
    .photo {
      position: absolute;
      top: 17mm;
      left: 4.5mm;
      width: 15mm;
      height: 19mm;
      background: #e0e4ee;
      border: 1.5px solid <%= primaryColor %>;
      overflow: hidden;
    }

    .photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo__placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      background: #d5d9e5;
    }


    /* ============================================================
       TEACHER INFO (right side)
       ============================================================ */
    .info {
      position: absolute;
      top: 17mm;
      left: 23mm;
      right: 3mm;
    }

    .info__name {
      margin-bottom: 1.5mm;
      font-size: 9pt;
      font-weight: 700;
      color: <%= primaryColor %>;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .info__divider {
      margin-bottom: 1.5mm;
      border-top: 0.5px solid #cccccc;
    }


    /* ============================================================
       INFO FIELD ROWS
       ============================================================ */
    .field {
      display: flex;
      align-items: baseline;
      margin-bottom: 1.2mm;
    }

    .field__label {
      flex-shrink: 0;
      width: 18mm;
      font-size: 5.5pt;
      color: #333333;
    }

    .field__colon {
      flex-shrink: 0;
      margin-right: 1mm;
      font-size: 5.5pt;
      color: #333333;
    }

    .field__value {
      font-size: 5.5pt;
      font-weight: 700;
      color: #cc0000;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }


    /* ============================================================
       BOTTOM ROW (QR + Signature)
       ============================================================ */
    .bottom {
      position: absolute;
      bottom: 2.5mm;
      left: 2.5mm;
      right: 2.5mm;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }

    .qr {
      width: 12mm;
      height: 12mm;
    }

    .qr svg {
      width: 100%;
      height: 100%;
    }


    /* ============================================================
       PRINCIPAL SIGNATURE
       ============================================================ */
    .signature {
      width: 24mm;
      text-align: center;
    }

    .signature__name {
      font-family: Georgia, serif;
      font-size: 5.5pt;
      font-style: italic;
      font-weight: 700;
      color: #333333;
    }

    .signature__line {
      margin: 1mm 0 0.5mm;
      border-top: 0.5px solid #333333;
    }

    .signature__title {
      font-size: 3.5pt;
      color: #333333;
    }
  </style>
</head>

<body>
  <div class="card">

    <!-- Header: Logo + School Name -->
    <div class="header">
      <div class="header__logo">
        <% if (logo) { %>
          <img src="<%= logo %>" alt="School Logo">
        <% } %>
      </div>

      <div class="header__text">
        <div class="header__school-name">
          <%= (schoolName || 'School Name').toUpperCase() %>
        </div>

        <% if (schoolAddress) { %>
          <div class="header__school-address">
            <%= schoolAddress %>
          </div>
        <% } %>
      </div>
    </div>


    <!-- Teacher Photo -->
    <div class="photo">
      <% if (photo) { %>
        <img src="<%= photo %>" alt="Teacher Photo">
      <% } else { %>
        <div class="photo__placeholder">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8a8fa8" stroke-width="1.5">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        </div>
      <% } %>
    </div>


    <!-- Teacher Info -->
    <div class="info">
      <div class="info__name"><%= name || 'Teacher Name' %></div>
      <div class="info__divider"></div>

      <div class="field">
        <span class="field__label">Designation</span>
        <span class="field__colon">:</span>
        <span class="field__value"><%= designation || 'Teacher' %></span>
      </div>

      <div class="field">
        <span class="field__label">Employee Id</span>
        <span class="field__colon">:</span>
        <span class="field__value"><%= staffId || 'N/A' %></span>
      </div>

      <div class="field">
        <span class="field__label">Class</span>
        <span class="field__colon">:</span>
        <span class="field__value"><%= cls || 'N/A' %></span>
      </div>

      <div class="field">
        <span class="field__label">Joining Date</span>
        <span class="field__colon">:</span>
        <span class="field__value"><%= joinDate || 'N/A' %></span>
      </div>
    </div>


    <!-- Bottom Row: QR + Signature -->
    <div class="bottom">
      <div class="qr">
        <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" fill="none" stroke="<%= primaryColor %>" stroke-width="1"/>
          <rect x="2" y="2" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="3.5" y="3.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="18" y="2" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="19.5" y="3.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="2" y="18" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="3.5" y="19.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="12" y="4" width="2" height="2" fill="<%= primaryColor %>"/>
          <rect x="14" y="8" width="2" height="2" fill="<%= primaryColor %>"/>
          <rect x="18" y="18" width="2" height="2" fill="<%= primaryColor %>"/>
          <rect x="22" y="22" width="2" height="2" fill="<%= primaryColor %>"/>
        </svg>
      </div>

      <div class="signature">
        <div class="signature__name"><%= principalName || 'Principal' %></div>
        <div class="signature__line"></div>
        <div class="signature__title">Principal Signature</div>
      </div>
    </div>

  </div>
</body>
</html>
