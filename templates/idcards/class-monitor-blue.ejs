<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Class Monitor ID Card - Diagonal Blue</title>

  <style>
    /* ============================================================
       RESET
       ============================================================ */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }


    /* ============================================================
       CARD CONTAINER (CR80: 85.6mm × 54mm)
       ============================================================ */
    body {
      width: 85.6mm;
      height: 54mm;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    .card {
      position: relative;
      width: 85.6mm;
      height: 54mm;
      background: #ffffff;
      overflow: hidden;
    }

    .card__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .card__content {
      position: absolute;
      inset: 0;
      z-index: 5;
    }


    /* ============================================================
       QR CODE (top-left)
       ============================================================ */
    .qr {
      position: absolute;
      top: 2.5mm;
      left: 4mm;
      width: 10mm;
      height: 10mm;
    }

    .qr svg {
      width: 100%;
      height: 100%;
    }


    /* ============================================================
       HEADER RIGHT (logo + school name on blue area)
       ============================================================ */
    .header-right {
      position: absolute;
      top: 2mm;
      left: 34mm;
      display: flex;
      align-items: center;
      gap: 1.5mm;
    }

    .header-right__logo {
      flex-shrink: 0;
      width: 8mm;
      height: 8mm;
    }

    .header-right__logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .header-right__school-name {
      font-size: 7pt;
      font-weight: 700;
      color: #ffffff;
    }

    .header-right__role-text {
      margin-top: 0.5mm;
      font-size: 4.5pt;
      color: #ffffff;
      letter-spacing: 0.5pt;
    }


    /* ============================================================
       SQUARE STUDENT PHOTO (left)
       ============================================================ */
    .photo {
      position: absolute;
      top: 16mm;
      left: 5.5mm;
      width: 19mm;
      height: 21mm;
      background: #e0e4ee;
      border: 1.5px solid <%= darkenColor %>;
      overflow: hidden;
    }

    .photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo__placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      background: #d0d5e8;
    }


    /* ============================================================
       INFO FIELDS (right)
       ============================================================ */
    .fields {
      position: absolute;
      top: 16mm;
      left: 29mm;
      right: 2mm;
    }

    .field {
      display: flex;
      align-items: baseline;
      margin-bottom: 1.6mm;
    }

    .field__label {
      flex-shrink: 0;
      width: 22mm;
      font-size: 5.5pt;
      color: #444444;
    }

    .field__colon {
      flex-shrink: 0;
      margin-right: 1mm;
      font-size: 5.5pt;
      color: #444444;
    }

    .field__value {
      font-size: 5.5pt;
      font-weight: 700;
      color: #111111;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }


    /* ============================================================
       FOOTER (bottom-left blue area)
       ============================================================ */
    .footer-text {
      position: absolute;
      bottom: 3.5mm;
      left: 4mm;
      width: 30mm;
    }

    .footer-text__address {
      font-size: 4pt;
      color: #ffffff;
    }

    .footer-text__phone {
      margin-top: 0.5mm;
      font-size: 4pt;
      font-weight: 700;
      color: #ffffff;
    }


    /* ============================================================
       SIGNATURE (bottom-right)
       ============================================================ */
    .signature {
      position: absolute;
      bottom: 3mm;
      right: 3mm;
      width: 24mm;
      text-align: center;
    }

    .signature__name {
      font-family: Georgia, serif;
      font-size: 5.5pt;
      font-style: italic;
      font-weight: 700;
      color: #333333;
    }

    .signature__line {
      margin: 1mm 0 0.5mm;
      border-top: 0.5px solid #333333;
    }

    .signature__title {
      font-size: 3.5pt;
      color: #333333;
    }
  </style>
</head>

<body>
  <div class="card">

    <!-- Diagonal Blue Decorations -->
    <svg
      class="card__bg"
      viewBox="0 0 242 153"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <!-- top-right diagonal -->
      <path
        d="M101 0 L242 0 L242 43 L77 43 Z"
        fill="<%= primaryColor %>"
      />

      <!-- bottom-left diagonal -->
      <path
        d="M0 128 L116 128 L97 153 L0 153 Z"
        fill="<%= primaryColor %>"
      />
    </svg>


    <div class="card__content">

      <!-- QR Code (top-left) -->
      <div class="qr">
        <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" fill="none" stroke="<%= primaryColor %>" stroke-width="1"/>
          <rect x="2" y="2" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="3.5" y="3.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="18" y="2" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="19.5" y="3.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="2" y="18" width="8" height="8" fill="none" stroke="<%= primaryColor %>" stroke-width="0.8"/>
          <rect x="3.5" y="19.5" width="5" height="5" fill="<%= primaryColor %>"/>
          <rect x="12" y="4" width="2" height="2" fill="<%= primaryColor %>"/>
          <rect x="18" y="18" width="2" height="2" fill="<%= primaryColor %>"/>
        </svg>
      </div>


      <!-- Header Right: Logo + School Name -->
      <div class="header-right">
        <div class="header-right__logo">
          <% if (logo) { %>
            <img src="<%= logo %>" alt="School Logo">
          <% } %>
        </div>

        <div class="header-right__text">
          <div class="header-right__school-name">
            <%= schoolName || 'School Name' %>
          </div>
          <div class="header-right__role-text">CLASS MONITOR</div>
        </div>
      </div>


      <!-- Square Student Photo -->
      <div class="photo">
        <% if (photo) { %>
          <img src="<%= photo %>" alt="Student Photo">
        <% } else { %>
          <div class="photo__placeholder">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8a90aa" stroke-width="1.5">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
          </div>
        <% } %>
      </div>


      <!-- Info Fields -->
      <div class="fields">
        <div class="field">
          <span class="field__label">Student Name</span>
          <span class="field__colon">:</span>
          <span class="field__value"><%= name || 'N/A' %></span>
        </div>

        <div class="field">
          <span class="field__label">Student ID</span>
          <span class="field__colon">:</span>
          <span class="field__value"><%= studentId || 'N/A' %></span>
        </div>

        <div class="field">
          <span class="field__label">Roll No</span>
          <span class="field__colon">:</span>
          <span class="field__value"><%= roll || 'N/A' %></span>
        </div>

        <div class="field">
          <span class="field__label">Class</span>
          <span class="field__colon">:</span>
          <span class="field__value"><%= cls || 'N/A' %></span>
        </div>
      </div>


      <!-- Footer: Address + Phone (in blue area) -->
      <div class="footer-text">
        <% if (schoolAddress) { %>
          <div class="footer-text__address"><%= schoolAddress %></div>
        <% } %>

        <% if (contact) { %>
          <div class="footer-text__phone"><%= contact %></div>
        <% } %>
      </div>


      <!-- Signature -->
      <div class="signature">
        <div class="signature__name"><%= principalName || 'Principal' %></div>
        <div class="signature__line"></div>
        <div class="signature__title">Principal Signature</div>
      </div>

    </div>
  </div>
</body>
</html>
