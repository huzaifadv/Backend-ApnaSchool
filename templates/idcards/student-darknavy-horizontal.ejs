<!DOCTYPE html>
<!-- STUDENT TEMPLATE 1 - Dark Navy Gold -->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student ID Card - Dark Navy Gold</title>
  <style>
    :root {
      --primary-color: <%= locals.primaryColor || '#c9a227' %>;
      --darken-color: <%= locals.darkenColor || '#a07d10' %>;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      width: 85.6mm;
      height: 54mm;
      overflow: hidden;
      font-family: 'Segoe UI', Arial, sans-serif;
    }
    .card {
      position: relative;
      width: 85.6mm;
      height: 54mm;
      background: #0d1b2a;
      overflow: hidden;
    }
    .card__bg {
      position: absolute;
      inset: 0; width: 100%; height: 100%;
      z-index: 1;
    }
    .card__content {
      position: absolute;
      inset: 0; z-index: 5;
    }

    /* LEFT GOLD BORDER */
    .left-border {
      position: absolute;
      top: 0; left: 0;
      width: 1mm;
      height: 100%;
      background: var(--primary-color);
    }

    /* TOP BAR */
    .top-bar {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 10mm;
      display: flex;
      align-items: center;
      gap: 2mm;
      padding: 0 2.5mm 0 3mm;
      border-bottom: 0.3mm solid rgba(201,162,39,0.3);
    }

    .logo-wrap {
      width: 7mm; height: 7mm;
      border: 0.4mm solid var(--primary-color);
      border-radius: 1mm;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }
    .logo-wrap img { width: 100%; height: 100%; object-fit: contain; }

    .school-info__name {
      font-size: 6.5pt;
      font-weight: 800;
      color: #ffffff;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .school-info__address {
      font-size: 3.5pt;
      color: #7a8a9a;
      margin-top: 0.3mm;
    }

    /* PHOTO */
    .photo {
      position: absolute;
      top: 12mm; left: 3mm;
      width: 20mm; height: 25mm;
      border: 0.6mm solid var(--primary-color);
      background: #162030;
      overflow: hidden;
    }
    .photo img { width: 100%; height: 100%; object-fit: cover; }
    .photo__placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
    }

    /* ROLL BADGE */
    .roll-badge {
      position: absolute;
      top: 12mm; left: 25mm;
      background: rgba(201,162,39,0.15);
      border: 0.3mm solid var(--primary-color);
      border-radius: 1mm;
      padding: 0.5mm 2mm;
      display: inline-flex;
      align-items: center;
    }
    .roll-badge__label {
      font-size: 4.5pt;
      color: rgba(255,255,255,0.5);
      margin-right: 1mm;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .roll-badge__value {
      font-size: 4.5pt;
      font-weight: 800;
      color: var(--primary-color);
      letter-spacing: 0.5px;
    }

    /* NAME */
    .student-name {
      position: absolute;
      top: 17mm; left: 25mm; right: 2mm;
      font-size: 10pt;
      font-weight: 800;
      color: #ffffff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* FIELDS */
    .fields {
      position: absolute;
      top: 23mm; left: 25mm; right: 2mm;
    }
    .field {
      display: flex;
      align-items: center;
      margin-bottom: 1.3mm;
    }
    .field__dot {
      width: 1.2mm; height: 1.2mm;
      background: var(--primary-color);
      border-radius: 50%;
      flex-shrink: 0;
      margin-right: 1.5mm;
    }
    .field__label {
      width: 14mm;
      font-size: 5pt;
      font-weight: 700;
      color: #7a8a9a;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .field__value {
      font-size: 5.5pt;
      font-weight: 800;
      color: #ffffff;
    }

    /* BOTTOM ROW */
    .bottom-row {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 11mm;
      display: flex;
      align-items: center;
      padding: 0 3mm;
      border-top: 0.3mm solid rgba(201,162,39,0.25);
    }
    .qr-code {
      width: 9mm; height: 9mm;
      background: #ffffff;
      padding: 0.5mm;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .qr-code img { width: 100%; height: 100%; object-fit: contain; filter: grayscale(100%); }

    .signature {
      position: absolute;
      bottom: 2mm; right: 2mm;
      width: 24mm;
      text-align: center;
    }
    .signature__name {
      font-family: Georgia, serif;
      font-size: 5.5pt;
      font-style: italic;
      font-weight: 700;
      color: var(--primary-color);
    }
    .signature__line {
      margin: 0.8mm 0 0.4mm;
      border-top: 0.4mm solid rgba(201,162,39,0.4);
    }
    .signature__title {
      font-size: 3pt;
      color: #7a8a9a;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  </style>
</head>
<body>
<div class="card">
  <svg class="card__bg" viewBox="0 0 242 153" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <!-- subtle grid -->
    <defs>
      <pattern id="g" width="12" height="12" patternUnits="userSpaceOnUse">
        <path d="M 12 0 L 0 0 0 12" fill="none" stroke="#1e2d3d" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="242" height="153" fill="url(#g)"/>
    <!-- left gold border -->
    <rect x="0" y="0" width="3" height="153" fill="<%= primaryColor %>"/>
    <!-- bottom gold bar -->
    <rect x="0" y="125" width="242" height="28" fill="#0a1520"/>
    <rect x="0" y="125" width="242" height="1" fill="<%= primaryColor %>" opacity="0.5"/>
  </svg>

  <div class="card__content">
    <!-- TOP BAR -->
    <div class="top-bar">
      <div class="logo-wrap">
        <% if (locals.logo) { %><img src="<%= locals.logo %>" alt="Logo">
        <% } else { %>
          <svg width="16" height="16" viewBox="0 0 40 40"><text x="20" y="29" text-anchor="middle" font-size="22" font-weight="900" fill="#c9a227" font-family="Arial">L</text></svg>
        <% } %>
      </div>
      <div>
        <div class="school-info__name"><%= schoolName || 'School Name' %></div>
        <% if (schoolAddress) { %><div class="school-info__address"><%= schoolAddress %></div><% } %>
      </div>
    </div>

    <!-- PHOTO -->
    <div class="photo">
      <% if (locals.photo) { %><img src="<%= locals.photo %>" alt="Photo">
      <% } else { %>
        <div class="photo__placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="1.2" opacity="0.5">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        </div>
      <% } %>
    </div>

    <!-- ROLL BADGE -->
    <div class="roll-badge">
      <span class="roll-badge__label">Roll No:</span>
      <span class="roll-badge__value"><%= roll || 'N/A' %></span>
    </div>

    <!-- NAME -->
    <div class="student-name"><%= name || 'Student Name' %></div>

    <!-- FIELDS -->
    <div class="fields">
      <div class="field">
        <div class="field__dot"></div>
        <span class="field__label">Class</span>
        <span class="field__value"><%= cls || 'N/A' %></span>
      </div>
      <div class="field">
        <div class="field__dot"></div>
        <span class="field__label">Student ID</span>
        <span class="field__value"><%= studentId || 'N/A' %></span>
      </div>
      <div class="field">
        <div class="field__dot"></div>
        <span class="field__label">Session</span>
        <span class="field__value"><%= session || 'N/A' %></span>
      </div>
      <div class="field">
        <div class="field__dot"></div>
        <span class="field__label">Issue Date</span>
        <span class="field__value"><%= issueDate || 'N/A' %></span>
      </div>
    </div>

    <!-- BOTTOM ROW -->
    <div class="bottom-row">
      <div class="qr-code">
        <% if (qrCode) { %><img src="<%= qrCode %>" alt="QR">
        <% } else { %>
          <svg viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
            <rect x="0" y="0" width="9" height="9" fill="#111"/><rect x="1" y="1" width="7" height="7" fill="#fff"/><rect x="2" y="2" width="5" height="5" fill="#111"/>
            <rect x="12" y="0" width="9" height="9" fill="#111"/><rect x="13" y="1" width="7" height="7" fill="#fff"/><rect x="14" y="2" width="5" height="5" fill="#111"/>
            <rect x="0" y="12" width="9" height="9" fill="#111"/><rect x="1" y="13" width="7" height="7" fill="#fff"/><rect x="2" y="14" width="5" height="5" fill="#111"/>
            <rect x="11" y="11" width="2" height="2" fill="#111"/><rect x="14" y="14" width="4" height="2" fill="#111"/>
          </svg>
        <% } %>
      </div>
    </div>

    <!-- SIGNATURE -->
    <div class="signature">
      <div class="signature__name"><%= principalName || 'Principal' %></div>
      <div class="signature__line"></div>
      <div class="signature__title">Principal Signature</div>
    </div>
  </div>
</div>
</body>
</html>